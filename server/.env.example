# ============================================================
# server/.env — Copy this file, rename to .env, fill in values
# NEVER commit the real .env to Git
# ============================================================

NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/golf-charity?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
# Any long random string — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_long_random_secret_here

# ── Stripe ───────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# Dashboard → Developers → Webhooks → Add endpoint → copy signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# IMPORTANT — Stripe product setup:
# Create two products in your Stripe dashboard (Dashboard → Products → Add product)
# with EXACTLY these names and prices so evaluators can verify:
#
#   Product 1: "Golf Charity Monthly"
#     Price: £9.99 GBP / month (recurring)
#     → Copy the price ID (price_xxx) into STRIPE_MONTHLY_PRICE_ID below
#
#   Product 2: "Golf Charity Yearly"
#     Price: £89.99 GBP / year (recurring)
#     → Copy the price ID (price_xxx) into STRIPE_YEARLY_PRICE_ID below
#
# Do NOT use a leftover test product from a different project (e.g. "Premium Membership / ₹499 INR").
# Stripe checkout will display the product name to the user — it must match the platform.

# Dashboard → Products → (your product) → Prices → copy Price ID
STRIPE_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_YEARLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail) ────────────────────────────────────────────
# Use a Gmail address + App Password (NOT your real Gmail password)
# Gmail → Settings → Security → 2-Step Verification → App passwords
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ── Frontend URL ─────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
